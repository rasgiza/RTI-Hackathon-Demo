		formatString: 0.00
		lineageTag: 10000005-0001-0001-0001-00000000001a
		sourceLineageTag: utilization_pct
		summarizeBy: average
		sourceColumn: utilization_pct

		annotation SummarizationSetBy = Automatic

	column event_type
