		lineageTag: 10000005-0001-0001-0001-000000000013
		sourceLineageTag: event_id
		summarizeBy: none
		sourceColumn: event_id

		annotation SummarizationSetBy = Automatic

	column event_timestamp
		dataType: dateTime
		formatString: General Date
		lineageTag: 10000005-0001-0001-0001-000000000014
		sourceLineageTag: event_timestamp
		summarizeBy: none
		sourceColumn: event_timestamp

		annotation SummarizationSetBy = Automatic

	column event_date
