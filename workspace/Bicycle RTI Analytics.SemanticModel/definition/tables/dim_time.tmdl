/// Time dimension (24 hours). One row per hour with period, rush hour, and demand tier classification.
table dim_time
	lineageTag: 10000003-0001-0001-0001-000000000001
	sourceLineageTag: [dim_time]

	column time_key
		dataType: int64
		formatString: 0
		lineageTag: 10000003-0001-0001-0001-000000000011
		sourceLineageTag: time_key
		summarizeBy: none
		sourceColumn: time_key

		annotation SummarizationSetBy = Automatic

	column hour_of_day
		dataType: int64
		formatString: 0
		lineageTag: 10000003-0001-0001-0001-000000000012
		sourceLineageTag: hour_of_day
		summarizeBy: none
